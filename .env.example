# ============================================================
# Variables de entorno para Docker Compose
# Copiar este archivo a .env y llenar con valores reales
#
# Uso:
#   cp .env.example .env
#   (editar .env con tus valores)
#   docker compose up --build
# ============================================================

# ---- Base de datos MySQL ----
MYSQL_ROOT_PASSWORD=password_seguro_aqui
MYSQL_DATABASE=nombre_de_bd_aqui

# ---- Credenciales BD (para Spring Boot)----
DB_ENDPOINT=db
DB_PORT=3306
DB_USERNAME=root


